# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://workspace:workspace@localhost:5432/workspace_ai?schema=public"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# ─── AI provider selection ───────────────────────────────────────────────────
# Which provider answers chat/summary/task prompts: openai | claude | gemini | ollama
LLM_PROVIDER=openai
# Which provider generates embeddings: openai | gemini | ollama
EMBEDDING_PROVIDER=openai

# IMPORTANT: the embedding dimension must match the EMBEDDING_PROVIDER + model.
#   openai text-embedding-3-small -> 1536
#   gemini text-embedding-004     -> 768
#   ollama nomic-embed-text       -> 768
# If you change provider/model, update this AND the vector(N) column in schema.prisma,
# then re-run the migration. Mixing dimensions will break vector search.
EMBEDDING_DIM=1536

# ─── Provider credentials (only the ones you use are required) ───────────────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest

GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Ollama runs locally, no key needed
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ─── Client ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
